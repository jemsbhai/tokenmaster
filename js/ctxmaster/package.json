{
  "name": "ctxmaster",
  "version": "0.0.1",
  "description": "Terminal context gauge and visualization layer for tokenmaster: zone-colored budget bar, token velocity, and turns-to-exhaustion for LLM context windows.",
  "type": "commonjs",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && node scripts/write-esm-stub.mjs",
    "pretest": "npm run build",
    "test": "node --test test/",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "llm",
    "tokens",
    "context-window",
    "terminal",
    "gauge",
    "cli",
    "visualization",
    "tokenmaster",
    "metering",
    "usage"
  ],
  "author": "Muntaser Syed <jemsbhai@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "tokenmaster": ">=0.1.0 <0.2.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jemsbhai/tokenmaster.git",
    "directory": "js/ctxmaster"
  },
  "bugs": {
    "url": "https://github.com/jemsbhai/tokenmaster/issues"
  },
  "homepage": "https://github.com/jemsbhai/tokenmaster#readme"
}
